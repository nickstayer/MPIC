## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 cache/options directory
.vs/

# Rider personal
.idea/

# mstest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Dotcover
*.dotcover

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.jc/

# Remotes (for WSL)
.remotes/

# Project files
*.csproj.user
*.vcxproj.user
*.props.user
*.midl.user

# Paket
.paket/paket.bootstrapper.exe
paket-files/

# F#
.fake/

# Boo
*.booproj.user

# NHibernate
nhibernate.config

# Tools
*.pyc
*.pyo
*.rbc
*.sass-cache
*.pid
*.seed
*.pid.lock

# Backup files
*~
*.bak
*.tmp
*.orig

# NuGet
packages/
*.nupkg
# Exclude the packages folder, but keep the packages.config file in the root of the project.
# It is not advisable to exclude the packages folder with the new project system (.Net Core).
# packages/
# !packages.config

# Roslyn
*.ruleset

# Microsoft User Secrets
secrets.json

# Service Fabric
*.sfproj.user

# Sonar
.sonarlint/
.sonarqube/

# Azure
.azure/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
